rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // A helper to validate standard IDs generated by Firebase (20 chars alphanumeric normally, but we use a reasonable cap)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profile ---
    function isValidUser(data) {
      // Validate schema
      let hasReq = data.keys().hasAll(['favoriteChannels', 'settings']);
      let favIsList = data.keys().hasAll(['favoriteChannels']) && data.favoriteChannels is list && data.favoriteChannels.size() <= 500;
      let settingsOk = data.keys().hasAll(['settings']) && data.settings is map && data.settings.keys().hasAll(['autoPlayNext']) && data.settings.autoPlayNext is bool;
      let displayOk = data.keys().hasAll(['displayName']) ? (data.displayName is string && data.displayName.size() <= 100) : true;
      return hasReq && favIsList && settingsOk && displayOk;
    }

    // --- Channel ---
    function isValidChannel(data) {
      let hasReq = data.keys().hasAll(['name', 'url']);
      let nameOk = data.keys().hasAll(['name']) && data.name is string && data.name.size() > 0 && data.name.size() <= 100;
      let urlOk = data.keys().hasAll(['url']) && data.url is string && data.url.size() > 0 && data.url.size() <= 1000 && data.url.matches('^https?://.*');
      let catOk = data.keys().hasAll(['category']) ? (data.category is string && data.category.size() <= 50) : true;
      let logoOk = data.keys().hasAll(['logo']) ? (data.logo is string && data.logo.size() <= 1000) : true;
      let descOk = data.keys().hasAll(['description']) ? (data.description is string && data.description.size() <= 500) : true;
      return hasReq && nameOk && urlOk && catOk && logoOk && descOk;
    }

    // --- Chat Message ---
    function isValidChatMessage(data) {
      let hasReq = data.keys().hasAll(['text', 'userId', 'displayName', 'timestamp']);
      let textOk = data.keys().hasAll(['text']) && data.text is string && data.text.size() > 0 && data.text.size() <= 600;
      let userIdOk = data.keys().hasAll(['userId']) && data.userId is string && data.userId == request.auth.uid;
      let displayOk = data.keys().hasAll(['displayName']) ? (data.displayName is string && data.displayName.size() <= 100) : true;
      let timeOk = data.keys().hasAll(['timestamp']) && data.timestamp == request.time;
      return hasReq && textOk && userIdOk && displayOk && timeOk && data.keys().size() <= 4;
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Collections ---
    
    match /channels/{channelId} {
      // Open reads for channels are required for the app to function for non-logged in users viewing categories.
      allow read: if true;
      
      allow create: if isSignedIn() 
                    && isValidId(channelId)
                    && isValidChannel(incoming())
                    && incoming().keys().size() <= 5; // Only allowed keys
                    
      allow update: if isSignedIn()
                    && isValidChannel(incoming());
                    
      allow delete: if false; // Only admins should delete channels ideally, disabled for now
      
      match /typing/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /messages/{messageId} {
        allow read: if true;
        allow list: if true;
        allow create: if isSignedIn()
                      && isValidId(messageId)
                      && isValidChatMessage(incoming());
        allow update, delete: if false;
      }
    }
    
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
                    && request.auth.uid == userId
                    && isValidId(userId)
                    && isValidUser(incoming());
                    
      allow update: if isSignedIn()
                    && request.auth.uid == userId
                    && isValidUser(incoming());
                    
      allow delete: if false;
    }
  }
}
